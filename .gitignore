# Repos da empresa = repos git PRÓPRIOS (polyrepo) — referenciados em repos.yml, não versionados aqui.
# (comentários só em linha própria — gitignore não aceita comentário inline)
# código local do doctor-hub (api/web):
/services/
# clones locais dos repos do manifest (make workspace) — visão de DEV:
/workspace/

# Segredos (nunca versionar) — usar .env.example + Secret Manager (GCP)
.env
*.env.local
.secrets/
infrastructure/envs/*.env

# Backups do banco (pg_dump do reset-ambiente.sh — contêm dados, nunca commitar)
infrastructure/backups/

# Handoff descartável entre sessões (autoexclui — nunca commitar)
_SESSION-START.md

# Sistema operacional / editores
.DS_Store
*.swp
.idea/
.vscode/
.secrets/
# Documentos pessoais/temporários (PII — nunca versionar)
temp/

# Arquivos prontos p/ upload (PII — nunca versionar)
output/
.e2e-env

# python cache dos scripts de homologação
infrastructure/scripts/__pycache__/

# permissões locais/pessoais do Claude Code (nunca compartilhar — pode referenciar infra/segredos)
.claude/settings.local.json
