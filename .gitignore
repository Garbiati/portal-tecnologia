# Repos da empresa = repos git PRÓPRIOS (polyrepo) — referenciados em repos.yml, não versionados aqui.
# (comentários só em linha própria — gitignore não aceita comentário inline)
# código local do doctor-hub (api/web):
/services/
# clones locais dos repos do manifest (make workspace) — visão de DEV:
/workspace/

# Segredos (nunca versionar) — usar .env.example + Secret Manager (GCP)
.env
*.env.local
.secrets/
infrastructure/envs/*.env

# Handoff descartável entre sessões (autoexclui — nunca commitar)
_SESSION-START.md

# Sistema operacional / editores
.DS_Store
*.swp
.idea/
.vscode/
