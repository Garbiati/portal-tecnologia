# Copie para terraform.tfvars (GITIGNORED) e preencha. NUNCA commite terraform.tfvars.
# Nenhum segredo aqui — só identificadores. Senhas são geradas pelo TF e guardadas no Secret Manager.

project_id     = "portal-tecnologia"            # projeto GCP PESSOAL
region         = "southamerica-east1"           # São Paulo (LGPD / latência BR)

# Imagem de prod do Keycloak (preencher após o 1º build/push — ver ../README.md):
keycloak_image = "southamerica-east1-docker.pkg.dev/portal-tecnologia/portal-identity/keycloak:1.0.0"

# Domínio próprio do IdP (plataforma). Vazio = usa só a URL *.run.app.
keycloak_domain = "id.portaltecnologia.app.br"
front_base_url  = "https://doctorhub.app.br"       # SITE Doctor-Hub (deployado depois) — redirects do realm

# Alternativa sem domínio: deixe keycloak_domain="" e preencha isto com a URL *.run.app após o 1º apply:
keycloak_hostname = ""

# Opcionais (têm default):
# db_tier          = "db-f1-micro"
# cloud_run_cpu    = "1"
# cloud_run_memory = "1024Mi"
